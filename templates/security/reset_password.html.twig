<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Réinitialiser mon mot de passe - {{ global_settings.agency_name|default('ImmoPro') }}</title>

    {# Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Playfair+Display:ital,wght@0,700;0,800;1,700&display=swap" rel="stylesheet">

    {# Icons #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    {# Tailwind CDN #}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        dark: '#0F172A',
                        premium: '#4F46E5',
                        gold: '#D4AF37',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    }
                }
            }
        }
    </script>

    <style>
        * { font-weight: 600; }
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }

        .input-field {
            width: 100%;
            padding: 0.9rem 1rem 0.9rem 3rem;
            background: rgba(15, 23, 42, 0.05);
            border: 1.5px solid #E2E8F0;
            border-radius: 0.875rem;
            font-size: 0.875rem;
            font-weight: 600;
            color: #0F172A;
            outline: none;
            transition: all 0.2s;
        }
        .input-field:focus {
            border-color: #4F46E5;
            background: white;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.08);
        }
        .input-field::placeholder { color: #94A3B8; font-weight: 500; }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(30px); }
            to   { opacity: 1; transform: translateX(0); }
        }
        .slide-in { animation: slideIn 0.5s ease forwards; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.4s ease forwards; }
        .delay-1 { animation-delay: 0.1s; opacity: 0; }
        .delay-2 { animation-delay: 0.2s; opacity: 0; }
        .delay-3 { animation-delay: 0.3s; opacity: 0; }
    </style>
</head>
<body class="bg-slate-50 text-dark">

<div class="min-h-screen flex relative">

    {# ===== LEFT PANEL — Photo ===== #}
    <div class="hidden lg:flex lg:w-1/2 xl:w-[55%] relative overflow-hidden">
        <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=85&w=1400"
             alt="Immobilier premium"
             class="absolute inset-0 w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-br from-dark/90 via-dark/70 to-indigo-900/60"></div>
        <div class="absolute z-10 flex flex-col justify-between p-12 w-full h-full">
            <div class="flex items-center gap-3 fade-up">
                <div class="h-10 w-10 rounded-xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center shadow-lg">
                    <i class="fa-solid fa-building text-white text-lg"></i>
                </div>
                <div class="flex flex-col leading-none">
                    <span class="font-serif text-xl font-black text-white tracking-tight">{{ global_settings.agency_name|default('ImmoPro') }}</span>
                    <span class="text-[9px] font-black uppercase tracking-[0.3em] text-gold">Premium</span>
                </div>
            </div>
            <div>
                <p class="text-[11px] font-black uppercase tracking-[0.3em] text-gold mb-5 fade-up delay-1">Sécurité</p>
                <h2 class="font-serif text-4xl xl:text-5xl text-white leading-tight mb-6 fade-up delay-2">
                    Définissez votre<br>nouveau mot<br><span class="italic text-indigo-300">de passe</span>
                </h2>
            </div>
            <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest fade-up delay-3">© {{ 'now'|date('Y') }} {{ global_settings.agency_name|default('ImmoPro') }}</p>
        </div>
    </div>

    {# ===== RIGHT PANEL — Form ===== #}
    <div class="w-full lg:w-1/2 xl:w-[45%] flex items-center justify-center p-6 sm:p-10 bg-white/80 backdrop-blur-sm">
        <div class="w-full max-w-md slide-in">

            {# Mobile logo #}
            <div class="flex items-center gap-2 mb-10 lg:hidden">
                <div class="h-8 w-8 rounded-lg bg-indigo-600 flex items-center justify-center">
                    <i class="fa-solid fa-building text-white text-sm"></i>
                </div>
                <span class="font-serif text-lg font-black text-dark">{{ global_settings.agency_name|default('ImmoPro') }}</span>
            </div>

            {# Header #}
            <div class="mb-10 fade-up delay-1">
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-indigo-500 mb-3">Réinitialisation</p>
                <h1 class="font-serif text-3xl xl:text-4xl text-dark leading-tight mb-2">
                    Nouveau mot<br>de <span class="italic text-indigo-600">passe</span>
                </h1>
                <p class="text-slate-500 text-sm mt-3">Saisissez un mot de passe robuste de 8 caractères minimum.</p>
            </div>

            {# Success / Error Messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-6 p-4 rounded-2xl flex items-start gap-3 fade-up {% if label == 'success' %}bg-emerald-50 border border-emerald-100 text-emerald-800{% else %}bg-rose-50 border border-rose-100 text-rose-800{% endif %}">
                        <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 {% if label == 'success' %}bg-emerald-100{% else %}bg-rose-100{% endif %}">
                            <i class="fa-solid {% if label == 'success' %}fa-circle-check text-emerald-500{% else %}fa-circle-exclamation text-rose-500{% endif %} text-sm"></i>
                        </div>
                        <div>
                            <p class="text-sm font-black {% if label == 'success' %}text-emerald-800{% else %}text-rose-700{% endif %}">Erreur</p>
                            <p class="text-xs {% if label == 'success' %}text-emerald-600{% else %}text-rose-500{% endif %} mt-0.5">{{ message }}</p>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {# Form #}
            <form method="post" class="space-y-5">
                <div class="fade-up delay-2">
                    <label for="inputPassword" class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">
                        Nouveau mot de passe
                    </label>
                    <div class="relative">
                        <div class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 flex items-center justify-center text-slate-400">
                            <i class="fa-solid fa-lock text-sm"></i>
                        </div>
                        <input type="password"
                               name="password"
                               id="inputPassword"
                               class="input-field"
                               required
                               autofocus
                               placeholder="••••••••">
                    </div>
                </div>

                <div class="fade-up delay-3">
                    <label for="inputConfirmPassword" class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">
                        Confirmez le mot de passe
                    </label>
                    <div class="relative">
                        <div class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 flex items-center justify-center text-slate-400">
                            <i class="fa-solid fa-lock text-sm"></i>
                        </div>
                        <input type="password"
                               name="confirm_password"
                               id="inputConfirmPassword"
                               class="input-field"
                               required
                               placeholder="••••••••">
                    </div>
                </div>

                <div class="fade-up delay-4">
                    <button type="submit"
                            class="w-full py-4 bg-indigo-600 text-white rounded-2xl text-xs font-black uppercase tracking-widest shadow-lg shadow-indigo-500/30 hover:bg-indigo-700 hover:shadow-indigo-500/40 hover:scale-[1.01] active:scale-[0.99] transition-all">
                        <i class="fa-solid fa-floppy-disk mr-2"></i>
                        Enregistrer le mot de passe
                    </button>
                </div>
            </form>

        </div>
    </div>

</div>

</body>
</html>
