<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - {{ global_settings.agency_name|default('ImmoPro') }}</title>
    <meta name="description" content="Connectez-vous à votre espace ImmoPro Premium">

    {# Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Playfair+Display:ital,wght@0,700;0,800;1,700&display=swap" rel="stylesheet">

    {# Icons #}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    {# Tailwind CDN #}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        dark: '#0F172A',
                        premium: '#4F46E5',
                        gold: '#D4AF37',
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    }
                }
            }
        }
    </script>

    <style>
        * { font-weight: 600; }
        body { font-family: 'Inter', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }

        .input-field {
            width: 100%;
            padding: 0.9rem 1rem 0.9rem 3rem;
            background: rgba(15, 23, 42, 0.05);
            border: 1.5px solid #E2E8F0;
            border-radius: 0.875rem;
            font-size: 0.875rem;
            font-weight: 600;
            color: #0F172A;
            outline: none;
            transition: all 0.2s;
        }
        .input-field:focus {
            border-color: #4F46E5;
            background: white;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.08);
        }
        .input-field::placeholder { color: #94A3B8; font-weight: 500; }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(30px); }
            to   { opacity: 1; transform: translateX(0); }
        }
        .slide-in { animation: slideIn 0.5s ease forwards; }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .fade-up { animation: fadeUp 0.4s ease forwards; }
        .delay-1 { animation-delay: 0.1s; opacity: 0; }
        .delay-2 { animation-delay: 0.2s; opacity: 0; }
        .delay-3 { animation-delay: 0.3s; opacity: 0; }
        .delay-4 { animation-delay: 0.4s; opacity: 0; }
        .delay-5 { animation-delay: 0.5s; opacity: 0; }
    </style>
</head>
<body class="bg-slate-50 text-dark">

<div class="min-h-screen flex relative">

    {# ===== LEFT PANEL — Photo ===== #}
    <div class="hidden lg:flex lg:w-1/2 xl:w-[55%] relative overflow-hidden">

        {# Background image #}
        <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=85&w=1400"
             alt="Immobilier premium"
             class="absolute inset-0 w-full h-full object-cover">

        {# Dark overlay #}
        <div class="absolute inset-0 bg-gradient-to-br from-dark/90 via-dark/70 to-indigo-900/60"></div>

        {# Right-edge blur bleed into form panel #}
        <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-r from-transparent to-white/10 backdrop-blur-xl" style="mask-image: linear-gradient(to right, transparent, white);-webkit-mask-image:linear-gradient(to right, transparent, white);"></div>

        {# Content over image #}
        <div class="relative z-10 flex flex-col justify-between p-12 w-full">

            {# Logo top-left #}
            <div class="flex items-center gap-3 fade-up">
                <div class="h-10 w-10 rounded-xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center shadow-lg">
                    <i class="fa-solid fa-building text-white text-lg"></i>
                </div>
                <div class="flex flex-col leading-none">
                    <span class="font-serif text-xl font-black text-white tracking-tight">{{ global_settings.agency_name|default('ImmoPro') }}</span>
                    <span class="text-[9px] font-black uppercase tracking-[0.3em] text-gold">Premium</span>
                </div>
            </div>

            {# Central quote #}
            <div>
                <p class="text-[11px] font-black uppercase tracking-[0.3em] text-gold mb-5 fade-up delay-1">Plateforme de Gestion Immobilière</p>
                <h2 class="font-serif text-4xl xl:text-5xl text-white leading-tight mb-6 fade-up delay-2">
                    Gérez votre<br>patrimoine avec<br><span class="italic text-indigo-300">excellence</span>
                </h2>
                <p class="text-slate-400 text-sm max-w-sm leading-relaxed fade-up delay-3">
                    Un outil complet pour les professionnels de l'immobilier : suivi des biens, transactions, clients et documents en un seul endroit.
                </p>

                {# Stats row #}
                <div class="mt-10 grid grid-cols-3 gap-4">
                    <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-4 text-center fade-up delay-4">
                        <p class="text-2xl font-black text-white">500+</p>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">Biens</p>
                    </div>
                    <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-4 text-center fade-up delay-4">
                        <p class="text-2xl font-black text-white">1200+</p>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">Clients</p>
                    </div>
                    <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl p-4 text-center fade-up delay-4">
                        <p class="text-2xl font-black text-white">98%</p>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-1">Satisfaction</p>
                    </div>
                </div>
            </div>

            {# Bottom tagline #}
            <div class="flex items-center gap-2 fade-up delay-5">
                <div class="h-px flex-1 bg-white/10"></div>
                <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest">© {{ 'now'|date('Y') }} {{ global_settings.agency_name|default('ImmoPro') }}</p>
                <div class="h-px flex-1 bg-white/10"></div>
            </div>
        </div>
    </div>

    {# ===== CENTER BLUR DIVIDER ===== #}
    <div class="hidden lg:block absolute left-[55%] xl:left-[55%] top-0 bottom-0 w-24 z-10 pointer-events-none" style="transform:translateX(-50%)">
        <div class="w-full h-full backdrop-blur-2xl bg-white/5" style="mask-image:linear-gradient(to right, transparent 0%, white 40%, white 60%, transparent 100%);-webkit-mask-image:linear-gradient(to right, transparent 0%, white 40%, white 60%, transparent 100%);"></div>
    </div>

    {# ===== RIGHT PANEL — Form ===== #}
    <div class="w-full lg:w-1/2 xl:w-[45%] flex items-center justify-center p-6 sm:p-10 bg-white/80 backdrop-blur-sm">
        <div class="w-full max-w-md slide-in">

            {# Mobile logo (visible only on mobile) #}
            <div class="flex items-center gap-2 mb-10 lg:hidden">
                <div class="h-8 w-8 rounded-lg bg-indigo-600 flex items-center justify-center">
                    <i class="fa-solid fa-building text-white text-sm"></i>
                </div>
                <span class="font-serif text-lg font-black text-dark">{{ global_settings.agency_name|default('ImmoPro') }}</span>
            </div>

            {# Header #}
            <div class="mb-10 fade-up delay-1">
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-indigo-500 mb-3">Bienvenue</p>
                <h1 class="font-serif text-3xl xl:text-4xl text-dark leading-tight mb-2">
                    Connexion à<br>votre <span class="italic text-indigo-600">espace</span>
                </h1>
                <p class="text-slate-500 text-sm mt-3">Entrez vos identifiants pour accéder à la plateforme.</p>
            </div>

            {# Error message #}
            {% if error %}
            <div class="mb-6 p-4 bg-rose-50 border border-rose-200 text-rose-700 rounded-2xl flex items-start gap-3 fade-up">
                <div class="w-8 h-8 rounded-full bg-rose-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                    <i class="fa-solid fa-circle-exclamation text-rose-500 text-sm"></i>
                </div>
                <div>
                    <p class="text-sm font-black text-rose-700">Identifiants incorrects</p>
                    <p class="text-xs text-rose-500 mt-0.5">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                </div>
            </div>
            {% endif %}

            {# Form #}
            <form method="post" class="space-y-5">

                {# Email #}
                <div class="fade-up delay-2">
                    <label for="inputEmail" class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">
                        Adresse Email
                    </label>
                    <div class="relative">
                        <div class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 flex items-center justify-center text-slate-400">
                            <i class="fa-solid fa-envelope text-sm"></i>
                        </div>
                        <input type="email"
                               value="{{ last_username }}"
                               name="email"
                               id="inputEmail"
                               class="input-field"
                               autocomplete="email"
                               required
                               autofocus
                               placeholder="votre@email.com">
                    </div>
                </div>

                {# Password #}
                <div class="fade-up delay-3">
                    <div class="flex justify-between items-center mb-2">
                        <label for="inputPassword" class="text-[10px] font-black uppercase tracking-widest text-slate-500">
                            Mot de passe
                        </label>
                        <a href="{{ path('app_forgot_password') }}" class="text-[10px] font-black text-indigo-500 hover:text-indigo-700 transition-colors uppercase tracking-widest">
                            Oublié ?
                        </a>
                    </div>
                    <div class="relative">
                        <div class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 flex items-center justify-center text-slate-400">
                            <i class="fa-solid fa-lock text-sm"></i>
                        </div>
                        <input type="password"
                               name="password"
                               id="inputPassword"
                               class="input-field pr-12"
                               autocomplete="current-password"
                               required
                               placeholder="••••••••">
                        <button type="button" 
                                onclick="const input = document.getElementById('inputPassword'); const icon = this.querySelector('i'); if(input.type === 'password') { input.type = 'text'; icon.classList.remove('fa-eye'); icon.classList.add('fa-eye-slash'); } else { input.type = 'password'; icon.classList.remove('fa-eye-slash'); icon.classList.add('fa-eye'); }"
                                class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 flex items-center justify-center text-slate-400 hover:text-indigo-500 transition-colors focus:outline-none"
                                title="Afficher/Masquer le mot de passe">
                            <i class="fa-solid fa-eye text-sm"></i>
                        </button>
                    </div>
                </div>

                {# Remember me #}
                <div class="flex items-center gap-3 fade-up delay-4">
                    <div class="relative flex items-center">
                        <input type="checkbox"
                               name="_remember_me"
                               id="rememberMe"
                               class="w-4 h-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 cursor-pointer">
                    </div>
                    <label for="rememberMe" class="text-sm text-slate-500 cursor-pointer hover:text-slate-700 transition-colors select-none">
                        Rester connecté
                    </label>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                {# Submit #}
                <div class="fade-up delay-5">
                    <button type="submit"
                            class="w-full py-4 bg-indigo-600 text-white rounded-2xl text-xs font-black uppercase tracking-widest shadow-lg shadow-indigo-500/30 hover:bg-indigo-700 hover:shadow-indigo-500/40 hover:scale-[1.01] active:scale-[0.99] transition-all">
                        <i class="fa-solid fa-arrow-right-to-bracket mr-2"></i>
                        Se connecter
                    </button>

                    <a href="{{ path('app_home') }}"
                       class="mt-4 w-full py-3.5 bg-slate-50 border border-slate-200 text-slate-600 rounded-2xl text-xs font-black uppercase tracking-widest hover:bg-slate-100 transition-all flex items-center justify-center">
                        <i class="fa-solid fa-arrow-left mr-2 text-slate-400"></i>
                        Retour à l'accueil
                    </a>
                </div>
            </form>

            {# Footer note #}
            <p class="mt-10 text-center text-xs text-slate-400 fade-up delay-5">
                Nouveau sur la plateforme ?<br>
                <a href="{{ path('app_register') }}" class="text-indigo-500 font-bold hover:text-indigo-700 transition-colors inline-block mt-1">Créez votre compte client</a>
            </p>

        </div>
    </div>

</div>

</body>
</html>
