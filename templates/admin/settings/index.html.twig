{% extends 'base.html.twig' %}

{% block title %}Configuration - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <div class="bg-dark pt-16 pb-12 relative overflow-hidden">
        <div class="absolute inset-0 z-0 opacity-20">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=80&w=2000" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-dark to-transparent"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-10">
            <div class="flex justify-between items-center">
                <div class="flex items-center">
                    <a href="{{ path('app_home') }}" class="mr-4 w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white/80 hover:text-white hover:bg-white/20 hover:scale-105 transition-all shadow-lg">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <h2 class="font-black text-3xl md:text-5xl text-white leading-tight">
                        Paramètres Système
                    </h2>
                </div>
            <div class="flex space-x-3">
                <span class="px-4 py-2 bg-white/10 backdrop-blur-md rounded-2xl text-[10px] font-black text-white uppercase tracking-widest border border-white/10">
                    Configuration Globale
                </span>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<div class="py-8 bg-slate-50/50 min-h-screen">
    <div class="max-w-4xl mx-auto sm:px-6 lg:px-8">
        
        <form action="{{ path('admin.settings.update') }}" method="POST" enctype="multipart/form-data" class="space-y-8">
            {# 1. Agence & Identité #}
            <div class="premium-card bg-white p-8">
                <div class="flex items-center mb-8 pb-4 border-b border-slate-50">
                    <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center mr-4">
                        <i class="fa-solid fa-building text-lg"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900">Identité de l'Agence</h3>
                        <p class="text-xs text-slate-400 font-medium">Informations légales et logo</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="col-span-full">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Nom de l'Agence</label>
                        <input type="text" name="agency_name" value="{{ settings.agency_name }}" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Directeur</label>
                        <input type="text" name="agency_director" value="{{ settings.agency_director }}" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Adresse Physique</label>
                        <input type="text" name="agency_address" value="{{ settings.agency_address }}" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>
                </div>
            </div>

            {# 2. Paramètres Financiers #}
            <div class="premium-card bg-white p-8">
                <div class="flex items-center mb-8 pb-4 border-b border-slate-50">
                    <div class="w-10 h-10 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center mr-4">
                        <i class="fa-solid fa-coins text-lg"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900">Finance & Taxes</h3>
                        <p class="text-xs text-slate-400 font-medium">Devises et taux de commission</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Devise</label>
                        <input type="text" name="currency" value="{{ settings.currency }}" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">TVA (%)</label>
                        <input type="number" name="tax_rate" value="{{ settings.tax_rate }}" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Commission Agent (%)</label>
                        <input type="number" name="agent_commission" value="{{ settings.agent_commission }}" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>
                </div>
            </div>

            {# 3. Contact & Support #}
            <div class="premium-card bg-white p-8">
                <div class="flex items-center mb-8 pb-4 border-b border-slate-50">
                    <div class="w-10 h-10 bg-rose-50 text-rose-600 rounded-xl flex items-center justify-center mr-4">
                        <i class="fa-solid fa-headset text-lg"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900">Contact Public</h3>
                        <p class="text-xs text-slate-400 font-medium">Coordonnées affichées aux clients</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Email de Contact</label>
                        <input type="email" name="contact_email" value="{{ settings.contact_email }}" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Téléphone SAV</label>
                        <input type="text" name="contact_phone" value="{{ settings.contact_phone }}" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                    </div>
                </div>
            </div>

            <div class="flex justify-end pt-4">
                <button type="submit" class="px-10 py-4 bg-slate-900 text-white rounded-2xl text-[10px] font-black uppercase tracking-[0.2em] shadow-2xl hover:bg-indigo-600 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300">
                    Enregistrer les modifications
                </button>
            </div>

            {# 4. Membres de l'Agence #}
            <div class="premium-card bg-white p-8">
                <div class="flex items-center mb-8 pb-4 border-b border-slate-50">
                    <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center mr-4">
                        <i class="fa-solid fa-users text-lg"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-slate-900">Membres de l'Agence</h3>
                        <p class="text-xs text-slate-400 font-medium">Configurez l'équipe (Directeur, Comptable, Responsable)</p>
                    </div>
                </div>

                <div class="space-y-8">
                    {# Membre 1 #}
                    <div class="p-6 bg-slate-50/50 rounded-2xl border border-slate-100/50 space-y-4">
                        <h4 class="text-xs font-black uppercase text-indigo-600 tracking-wider">Membre 1 (ex: Directeur)</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Nom Complet</label>
                                <input type="text" name="team_member_1_name" value="{{ settings.team_member_1_name|default('') }}" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                            </div>
                            <div>
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Rôle / Titre</label>
                                <input type="text" name="team_member_1_role" value="{{ settings.team_member_1_role|default('') }}" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                            </div>
                            <div class="col-span-full">
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Photo</label>
                                <input type="file" name="team_member_1_photo" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                                {% if settings.team_member_1_photo|default(false) %}
                                    <div class="mt-2 flex items-center gap-2">
                                        <img src="{{ asset(settings.team_member_1_photo) }}" class="w-10 h-10 rounded-full object-cover border border-slate-200">
                                        <span class="text-xs text-slate-400">Photo actuelle</span>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# Membre 2 #}
                    <div class="p-6 bg-slate-50/50 rounded-2xl border border-slate-100/50 space-y-4">
                        <h4 class="text-xs font-black uppercase text-indigo-600 tracking-wider">Membre 2 (ex: Comptable)</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Nom Complet</label>
                                <input type="text" name="team_member_2_name" value="{{ settings.team_member_2_name|default('') }}" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                            </div>
                            <div>
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Rôle / Titre</label>
                                <input type="text" name="team_member_2_role" value="{{ settings.team_member_2_role|default('') }}" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                            </div>
                            <div class="col-span-full">
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Photo</label>
                                <input type="file" name="team_member_2_photo" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                                {% if settings.team_member_2_photo|default(false) %}
                                    <div class="mt-2 flex items-center gap-2">
                                        <img src="{{ asset(settings.team_member_2_photo) }}" class="w-10 h-10 rounded-full object-cover border border-slate-200">
                                        <span class="text-xs text-slate-400">Photo actuelle</span>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    {# Membre 3 #}
                    <div class="p-6 bg-slate-50/50 rounded-2xl border border-slate-100/50 space-y-4">
                        <h4 class="text-xs font-black uppercase text-indigo-600 tracking-wider">Membre 3 (ex: Responsable)</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Nom Complet</label>
                                <input type="text" name="team_member_3_name" value="{{ settings.team_member_3_name|default('') }}" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                            </div>
                            <div>
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Rôle / Titre</label>
                                <input type="text" name="team_member_3_role" value="{{ settings.team_member_3_role|default('') }}" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                            </div>
                            <div class="col-span-full">
                                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 ml-1">Photo</label>
                                <input type="file" name="team_member_3_photo" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl text-sm font-bold text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 focus:border-indigo-500 transition-all">
                                {% if settings.team_member_3_photo|default(false) %}
                                    <div class="mt-2 flex items-center gap-2">
                                        <img src="{{ asset(settings.team_member_3_photo) }}" class="w-10 h-10 rounded-full object-cover border border-slate-200">
                                        <span class="text-xs text-slate-400">Photo actuelle</span>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>

    </div>
</div>
{% endblock %}
