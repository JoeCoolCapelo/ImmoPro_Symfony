{% extends 'base.html.twig' %}

{% block title %}Gestion des Utilisateurs - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <div class="bg-dark pt-16 pb-24 relative overflow-hidden">
        <div class="absolute inset-0 z-0 opacity-20">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=80&w=2000" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-dark to-transparent"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-10">
            <div class="flex justify-between items-end">
                <div class="flex items-center">
                    <a href="{{ path('app_home') }}" class="mr-4 w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white/80 hover:text-white hover:bg-white/20 hover:scale-105 transition-all shadow-lg">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <div>
                        <h2 class="font-serif text-3xl md:text-5xl text-white leading-tight">
                            Gestion des <span class="italic text-indigo-400">Utilisateurs</span>
                        </h2>
                        <p class="text-slate-400 mt-2 text-sm">Gérez les accès, rôles et comptes de la plateforme.</p>
                    </div>
                </div>
                <div>
                    <a href="{{ path('admin.users.create') }}" class="btn-premium !bg-white !text-dark hover:!bg-indigo-600 hover:!text-white shadow-xl shadow-black/20 flex items-center">
                        <i class="fa-solid fa-plus mr-2"></i> Nouvel Utilisateur
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="py-8 bg-slate-50 min-h-screen -mt-16 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-6 p-4 rounded-xl {% if label == 'success' %}bg-emerald-50 text-emerald-700 border border-emerald-200{% else %}bg-rose-50 text-rose-700 border border-rose-200{% endif %} flex items-center shadow-sm">
                    <i class="fa-solid {% if label == 'success' %}fa-check-circle text-emerald-500{% else %}fa-circle-exclamation text-rose-500{% endif %} mr-3 text-lg"></i>
                    <span class="font-bold text-sm">{{ message }}</span>
                </div>
            {% endfor %}
        {% endfor %}

        {# Filtre #}
        <div class="premium-card p-6 mb-6 bg-white shadow-sm">
            <form action="{{ path('admin.users') }}" method="GET" class="flex flex-col md:flex-row md:items-end gap-4">
                <div class="flex-1">
                    <label for="search" class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Recherche</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fa-solid fa-magnifying-glass text-slate-400"></i>
                        </div>
                        <input type="text" name="search" id="search" value="{{ app.request.query.get('search') }}"
                            class="pl-10 block w-full rounded-xl border-slate-200 bg-slate-50 focus:border-indigo-500 focus:ring-0 transition-colors text-sm py-3 font-bold text-slate-700"
                            placeholder="Nom ou adresse email...">
                    </div>
                </div>
                <div class="flex gap-3 mt-4 md:mt-0 w-full md:w-auto shrink-0">
                    <button type="submit" class="btn-premium flex items-center justify-center px-5 !bg-slate-900 hover:!bg-slate-800">
                        <i class="fa-solid fa-filter mr-2"></i> Filtrer
                    </button>
                    <!-- PDF / CSV Export buttons placeholders for future -->
                </div>
            </form>
        </div>

        {# VUE CARTES #}
        {% set role_labels = {
            'ROLE_SUPER_ADMIN': 'Super Administrateur',
            'ROLE_ADMIN': 'Administrateur (Directeur)',
            'ROLE_AGENT': 'Agent Immobilier',
            'ROLE_PROPRIETAIRE': 'Propriétaire',
            'ROLE_CLIENT': 'Client'
        } %}

        {% if users is empty %}
            <div class="premium-card p-20 text-center bg-white shadow-sm">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fa-solid fa-users text-4xl text-slate-200"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-900">Aucun utilisateur trouvé.</h3>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                {% for user in users %}
                    <div data-aos="fade-up" data-aos-delay="{{ loop.index0 * 50 }}" class="premium-card bg-white p-6 flex flex-col items-center text-center group hover:-translate-y-1 transition-all shadow-sm hover:shadow-xl border border-transparent hover:border-indigo-100">
                        <div class="h-20 w-20 rounded-full overflow-hidden bg-slate-900 flex items-center justify-center text-white font-black text-2xl shadow-lg mb-4 ring-4 ring-slate-50 group-hover:ring-indigo-50 transition-all">
                            {{ user.name|slice(0, 1)|upper }}
                        </div>
                        
                        <h3 class="text-base font-black text-slate-900 mb-1 group-hover:text-indigo-600 transition-colors line-clamp-1">{{ user.name }}</h3>
                        <p class="text-[11px] font-bold text-slate-400 mb-4 truncate w-full">{{ user.email }}</p>
                        
                        <span class="px-3 py-1 bg-indigo-50 text-indigo-700 text-[9px] font-black uppercase tracking-widest rounded-full border border-indigo-100 mb-4">
                            {{ role_labels[user.roles|first|default('')] | default('Utilisateur') }}
                        </span>

                        <div class="mt-auto w-full pt-4 border-t border-slate-100 flex justify-between items-center">
                            <span class="text-[9px] font-black uppercase tracking-widest text-slate-300">
                                <i class="fa-regular fa-calendar mr-1"></i> {{ user.createdAt|date('d/m/y') }}
                            </span>
                            
                            <div class="flex items-center gap-1">
                                <a href="{{ path('admin.users.edit', {id: user.id}) }}" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-xl transition-all" title="Modifier">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                {% if app.user.id != user.id and is_granted('ROLE_SUPER_ADMIN') %}
                                    <form action="{{ path('admin.users.destroy', {id: user.id}) }}" method="POST" class="inline-block" onsubmit="return confirm('Supprimer {{ user.name|escape('js') }} définitivement ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button type="submit" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-all" title="Supprimer">
                                            <i class="fa-solid fa-trash-can"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="mt-10 flex justify-center">
                {{ knp_pagination_render(users) }}
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
