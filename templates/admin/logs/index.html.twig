{% extends 'base.html.twig' %}

{% block title %}Journal d'Audit - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <div class="bg-dark pt-16 pb-24 relative overflow-hidden">
        <div class="absolute inset-0 z-0 opacity-20">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=80&w=2000" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-dark to-transparent"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-10">
            <div class="flex justify-between items-center">
                <div class="flex items-center">
                    <a href="{{ path('app_home') }}" class="mr-4 w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white/80 hover:text-white hover:bg-white/20 hover:scale-105 transition-all shadow-lg">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <h2 class="font-serif text-3xl md:text-5xl text-white leading-tight">
                        Journal d'<span class="italic text-indigo-400">Audit</span>
                    </h2>
                </div>
                <div class="text-[10px] font-black text-white uppercase tracking-widest bg-white/10 px-4 py-2 rounded-xl backdrop-blur-sm border border-white/10">
                    Sécurité & Traçabilité
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="py-8 bg-slate-50 min-h-screen -mt-16 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {# Filters Form #}
        <div class="premium-card bg-white p-6 mb-8 shadow-sm">
            <form action="{{ path('admin.logs') }}" method="GET" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block">Utilisateur</label>
                    <select name="user_id" class="w-full bg-slate-50 border-slate-200 rounded-xl text-xs font-bold text-slate-700 focus:ring-indigo-500 focus:border-indigo-500 py-3 px-4">
                        <option value="">Tous les utilisateurs</option>
                        {% for user in users %}
                            <option value="{{ user.id }}" {% if app.request.query.get('user_id') == user.id %}selected{% endif %}>{{ user.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block">Action</label>
                    <input type="text" name="event" value="{{ app.request.query.get('event') }}" placeholder="Ex: created, updated..." class="w-full bg-slate-50 border-slate-200 rounded-xl text-xs font-bold text-slate-700 focus:ring-indigo-500 focus:border-indigo-500 py-3 px-4">
                </div>
                <div class="md:col-span-1 grid grid-cols-2 gap-2">
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block">Du</label>
                        <input type="date" name="from" value="{{ app.request.query.get('from') }}" class="w-full bg-slate-50 border-slate-200 rounded-xl text-xs font-bold text-slate-700 focus:ring-indigo-500 focus:border-indigo-500 py-3 px-4">
                    </div>
                    <div>
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 block">Au</label>
                        <input type="date" name="to" value="{{ app.request.query.get('to') }}" class="w-full bg-slate-50 border-slate-200 rounded-xl text-xs font-bold text-slate-700 focus:ring-indigo-500 focus:border-indigo-500 py-3 px-4">
                    </div>
                </div>
                <div class="flex gap-2">
                    <button type="submit" class="btn-premium flex-1 py-3 !bg-slate-900 hover:!bg-indigo-600">
                        <i class="fa-solid fa-filter mr-2"></i> Filtrer
                    </button>
                    <a href="{{ path('admin.logs') }}" class="px-4 py-3 bg-slate-100 text-slate-500 rounded-xl hover:bg-slate-200 transition-colors flex items-center justify-center">
                        <i class="fa-solid fa-rotate-left"></i>
                    </a>
                </div>
            </form>
        </div>

        <div class="premium-card overflow-hidden bg-white shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-900 text-white">
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest">Date</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest">Utilisateur</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest">Action</th>
                            <th class="px-6 py-4 text-[10px] font-black uppercase tracking-widest">Modèle</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        {% for activity in activities %}
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap text-[10px] font-bold text-slate-500">
                                    {{ activity.createdAt|date('d/m/Y H:i') }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="h-8 w-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 text-[10px] font-black mr-3">
                                            {{ activity.causer.name|default('S')|slice(0, 1)|upper }}
                                        </div>
                                        <span class="text-xs font-black text-slate-800">{{ activity.causer.name|default('Système') }}</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-tighter 
                                        {% if activity.description == 'created' %}bg-emerald-50 text-emerald-600{% elseif activity.description == 'updated' %}bg-indigo-50 text-indigo-600{% else %}bg-rose-50 text-rose-600{% endif %}">
                                        {{ activity.description }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-xs font-bold text-slate-600">
                                    {{ activity.subjectType|split('\\')|last }} #{{ activity.subjectId }}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="px-6 py-12 text-center text-slate-400 text-xs font-bold">
                                    <i class="fa-solid fa-clipboard-list text-3xl mb-3 text-slate-200"></i>
                                    <br>Aucune activité n'a encore été enregistrée dans le journal.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {# Pagination placeholder if we implement KnpPaginator for logs later #}
        </div>
    </div>
</div>
{% endblock %}
