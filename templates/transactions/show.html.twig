{% extends 'base.html.twig' %}

{% block title %}Transaction #{{ transaction.id|format("%05d") }} - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8">
        <div class="flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <a href="{{ path('transactions.index') }}" class="p-2 bg-white rounded-xl shadow-sm border border-slate-100 hover:bg-slate-50 transition-colors text-slate-600">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>
                <h2 data-aos="fade-left" data-aos-delay="100" class="font-black text-2xl text-white leading-tight">
                    Transaction #{{ transaction.id|format("%05d") }}
                </h2>
            </div>
            <span data-aos="fade-left" data-aos-delay="200" class="status-badge {{ transaction.type == 'vente' ? 'bg-indigo-50 text-indigo-600' : 'bg-emerald-50 text-emerald-600' }}">
                {{ transaction.type|upper }}
            </span>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="py-12 bg-slate-50/50 min-h-screen">
    <div class="max-w-7xl mx-auto sm:px-6 lg:px-8">
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            {# Main Info #}
            <div class="lg:col-span-2 space-y-8">
                <div data-aos="fade-up" data-aos-delay="300" class="premium-card p-10 bg-white">
                    <div class="flex justify-between items-start border-b border-slate-50 pb-8 mb-8">
                        <div>
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Montant</p>
                            <h3 class="text-4xl font-black text-indigo-600">
                                {{ transaction.montant|number_format(0, ',', ' ') }} <small class="text-sm">GNF</small>
                            </h3>
                        </div>
                        <div class="text-right">
                            <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Date de l'acte</p>
                            <p class="text-lg font-black text-slate-800">{{ transaction.createdAt|date('d F Y') }}</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <div>
                            <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4">Bien Immobilier</h4>
                            {% if transaction.bien %}
                                <a href="{{ path('biens.show', {id: transaction.bien.id}) }}" class="flex items-center p-4 bg-slate-50 rounded-2xl hover:bg-slate-100 transition-colors border border-slate-100">
                                    <div class="h-12 w-12 rounded-xl overflow-hidden mr-4 bg-slate-200">
                                        {% if transaction.bien.images|length > 0 %}
                                            <img src="{{ asset(transaction.bien.images[0].path) }}" class="w-full h-full object-cover">
                                        {% endif %}
                                    </div>
                                    <div>
                                        <p class="font-black text-slate-800 text-sm">{{ transaction.bien.titre }}</p>
                                        <p class="text-[10px] text-slate-400 font-bold uppercase">{{ transaction.bien.ville }}</p>
                                    </div>
                                </a>
                            {% endif %}
                        </div>
                        <div>
                            <h4 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4">Agent Responsable</h4>
                            <div class="flex items-center p-4">
                                <div class="h-10 w-10 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-600 font-black text-xs">
                                    {{ transaction.agent ? transaction.agent.name|slice(0, 1)|upper : '?' }}
                                </div>
                                <div class="ms-3">
                                    <p class="font-black text-slate-800 text-sm">{{ transaction.agent ? transaction.agent.name : 'Inconnu' }}</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase">Agent ImmoPro</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {# Digital Signature Section #}
                <div data-aos="fade-up" data-aos-delay="400" class="premium-card p-10 bg-white border-2 {{ (transaction.isClientSigned and transaction.isOwnerSigned and transaction.isAgencySigned) ? 'border-emerald-500' : 'border-amber-200' }}">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center">
                            <i class="fa-solid fa-file-signature mr-3 text-indigo-600"></i> Accord Formel (Signature)
                        </h3>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        {# Client Signature #}
                        <div class="p-6 rounded-[2rem] {{ transaction.isClientSigned ? 'bg-emerald-50' : 'bg-slate-50' }} border border-slate-100">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Le Client</p>
                            <p class="font-black text-slate-900 text-sm">{{ transaction.client ? transaction.client.name : 'N/A' }}</p>
                            {% if transaction.isClientSigned %}
                                <div class="mt-4">
                                    <img src="{{ transaction.clientSignatureImage }}" class="h-10 border border-white rounded bg-white mx-auto">
                                </div>
                            {% elseif app.user == transaction.client %}
                                <button onclick="openSignatureModal()" class="mt-4 w-full py-2 bg-slate-900 text-white text-[10px] font-black uppercase rounded-xl hover:bg-indigo-600 transition">Signer</button>
                            {% endif %}
                        </div>

                        {# Owner Signature #}
                        <div class="p-6 rounded-[2rem] {{ transaction.isOwnerSigned ? 'bg-emerald-50' : 'bg-slate-50' }} border border-slate-100">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Le Propriétaire</p>
                            <p class="font-black text-slate-900 text-sm">{{ transaction.bien and transaction.bien.owner ? transaction.bien.owner.name : 'N/A' }}</p>
                            {% if transaction.isOwnerSigned %}
                                <div class="mt-4">
                                    <img src="{{ transaction.ownerSignatureImage }}" class="h-10 border border-white rounded bg-white mx-auto">
                                </div>
                            {% elseif transaction.bien and app.user == transaction.bien.owner %}
                                <button onclick="openSignatureModal()" class="mt-4 w-full py-2 bg-slate-900 text-white text-[10px] font-black uppercase rounded-xl hover:bg-indigo-600 transition">Signer</button>
                            {% endif %}
                        </div>

                        {# Agency Signature #}
                        <div class="p-6 rounded-[2rem] {{ transaction.isAgencySigned ? 'bg-indigo-50' : 'bg-slate-50' }} border border-slate-100">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">L'Agence</p>
                            <p class="font-black text-slate-900 text-sm">ImmoPro Direction</p>
                            {% if transaction.isAgencySigned %}
                                <div class="mt-4">
                                    <img src="{{ transaction.agencySignatureImage }}" class="h-10 border border-white rounded bg-white mx-auto">
                                </div>
                            {% elseif is_granted('ROLE_SUPER_ADMIN') or (is_granted('ROLE_AGENT') and transaction.agent == app.user) %}
                                <button onclick="openSignatureModal()" class="mt-4 w-full py-2 bg-slate-900 text-white text-[10px] font-black uppercase rounded-xl hover:bg-indigo-600 transition">Signer</button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            {# Sidebar #}
            <div class="space-y-8">
                <div data-aos="fade-left" data-aos-delay="500" class="bg-slate-950 p-8 rounded-[2.5rem] text-white shadow-2xl relative border border-slate-800">
                    <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500 mb-6">Récapitulatif</h4>
                    
                    <div class="space-y-4">
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400 text-xs font-bold">Montant Brut</span>
                            <span class="font-black text-white text-lg">{{ transaction.montant|number_format(0, ',', ' ') }} GNF</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-slate-400 text-xs font-bold">Commission ({{ transaction.commissionPourcentage|number_format(0) }}%)</span>
                            <span class="font-black text-emerald-400 text-lg">{{ transaction.commissionMontant|number_format(0, ',', ' ') }} GNF</span>
                        </div>
                    </div>

                    <div class="border-t border-slate-800 my-6"></div>

                    <div class="flex flex-col gap-3">
                        {# 1. TÉLÉCHARGER LE CONTRAT #}
                        {% if transaction.isClientSigned and transaction.isOwnerSigned and transaction.isAgencySigned %}
                            <a href="{{ path('transactions.pdf', {id: transaction.id}) }}" class="w-full py-4 bg-slate-900 hover:bg-slate-800 text-white text-center rounded-2xl text-[11px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-3 border border-slate-850 shadow-md">
                                <i class="fa-solid fa-file-contract text-slate-400"></i> Télécharger le contrat
                            </a>
                        {% else %}
                            <button disabled class="w-full py-4 bg-slate-900/50 text-white/30 text-center rounded-2xl text-[11px] font-black uppercase tracking-widest flex items-center justify-center gap-3 cursor-not-allowed border border-slate-800/50" title="En attente de signature de toutes les parties">
                                <i class="fa-solid fa-lock opacity-30"></i> Télécharger le contrat (Non signé)
                            </button>
                        {% endif %}

                        {% if transaction.type == 'location' %}
                            {# 2. GÉNÉRER LA QUITTANCE (Si location et paiement payé existant) #}
                            {% if latestPaidPayment %}
                                <a href="{{ path('paiements.pdf', {id: latestPaidPayment.id}) }}" class="w-full py-4 bg-white hover:bg-slate-100 text-slate-900 text-center rounded-2xl text-[11px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-3 shadow-lg">
                                    <i class="fa-solid fa-file-invoice text-slate-800"></i> Générer la Quittance
                                </a>
                            {% else %}
                                <button disabled class="w-full py-4 bg-slate-900/50 text-white/30 text-center rounded-2xl text-[11px] font-black uppercase tracking-widest flex items-center justify-center gap-3 cursor-not-allowed border border-slate-800/50">
                                    <i class="fa-solid fa-file-invoice opacity-30"></i> Générer la Quittance
                                </button>
                            {% endif %}

                            {# 3. SUIVI DES LOYERS MENSUELS #}
                            <a href="{{ path('paiements.index', {id: transaction.id}) }}" class="w-full py-4 bg-slate-900 hover:bg-slate-800 text-white text-center rounded-2xl text-[11px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-3 border border-slate-850 shadow-md">
                                <i class="fa-solid fa-wallet text-slate-400"></i> Suivi des loyers mensuels
                            </a>

                            {# 4. LIBÉRER LE BIEN #}
                            <form method="POST" action="{{ path('transactions.liberer', {id: transaction.id}) }}" onsubmit="return confirm('Confirmer la fin de location ? Le bien redeviendra disponible et la transaction sera clôturée.')" class="w-full">
                                <button type="submit" class="w-full py-4 bg-rose-50 hover:bg-rose-100 text-rose-600 rounded-2xl text-[11px] font-black uppercase tracking-widest transition-all flex items-center justify-center gap-3">
                                    <i class="fa-solid fa-door-open"></i> Libérer le bien
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Signature Modal #}
<div id="signatureModal" class="fixed inset-0 bg-slate-900/80 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4 transition-opacity duration-300">
    <div class="bg-white rounded-[2.5rem] w-full max-w-lg overflow-hidden shadow-2xl">
        <div class="p-8 bg-slate-900 text-white flex justify-between items-center">
            <h3 class="font-black text-lg uppercase tracking-widest flex items-center">Dessinez votre signature</h3>
            <button onclick="closeSignatureModal()" class="text-white/50 hover:text-white transition">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
        </div>
        
        <div class="p-8">
            <div class="border-2 border-dashed border-slate-200 rounded-2xl bg-slate-50 relative overflow-hidden mb-4">
                <canvas id="signatureCanvas" class="w-full h-48 cursor-crosshair touch-none"></canvas>
            </div>
            
            <form id="signatureForm" method="POST" action="{{ path('transactions.sign', {id: transaction.id}) }}">
                <input type="hidden" name="signature_data" id="signatureData">
                
                <div class="flex items-center justify-between mt-6">
                    <button type="button" onclick="clearSignature()" class="px-4 py-2 text-rose-500 font-black uppercase text-[10px]">Effacer</button>
                    <button type="button" onclick="saveSignature()" class="px-6 py-3 bg-indigo-600 text-white rounded-xl text-[10px] font-black uppercase shadow-lg">Valider</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const canvas = document.getElementById('signatureCanvas');
    const ctx = canvas.getContext('2d');
    let isDrawing = false;

    function resizeCanvas() {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
        ctx.lineWidth = 3;
        ctx.lineCap = 'round';
        ctx.strokeStyle = '#0f172a';
    }

    canvas.addEventListener('mousedown', () => isDrawing = true);
    canvas.addEventListener('mousemove', (e) => {
        if (!isDrawing) return;
        const rect = canvas.getBoundingClientRect();
        ctx.lineTo(e.clientX - rect.left, e.clientY - rect.top);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(e.clientX - rect.left, e.clientY - rect.top);
    });
    canvas.addEventListener('mouseup', () => { isDrawing = false; ctx.beginPath(); });

    function openSignatureModal() {
        document.getElementById('signatureModal').classList.remove('hidden');
        resizeCanvas();
    }

    function closeSignatureModal() {
        document.getElementById('signatureModal').classList.add('hidden');
        clearSignature();
    }

    function clearSignature() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
    }

    function saveSignature() {
        const dataUrl = canvas.toDataURL('image/png');
        document.getElementById('signatureData').value = dataUrl;
        document.getElementById('signatureForm').submit();
    }
</script>
{% endblock %}
