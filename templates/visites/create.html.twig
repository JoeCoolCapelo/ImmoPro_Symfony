{% extends 'base.html.twig' %}

{% block title %}Demande de Visite - {{ bien.titre }}{% endblock %}

{% block header %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 flex justify-between items-center">
        <h2 class="font-black text-xl text-white leading-tight">
            Programmer une Visite
        </h2>
        <a href="{{ path('biens.show', {id: bien.id}) }}" class="px-5 py-2 bg-white/10 hover:bg-white/20 text-white rounded-xl text-xs font-black uppercase tracking-widest transition-all">
            <i class="fa-solid fa-arrow-left mr-2"></i> Retour au bien
        </a>
    </div>
{% endblock %}

{% block content %}
<div class="py-12 bg-slate-50 min-h-screen">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="premium-card bg-white p-8 md:p-12">
            
            <div class="flex items-center gap-6 mb-8 pb-8 border-b border-slate-100">
                <div class="w-24 h-24 rounded-2xl overflow-hidden bg-slate-100 flex-shrink-0">
                    {% if bien.image %}
                        <img src="{{ asset(bien.image) }}" class="w-full h-full object-cover">
                    {% else %}
                        <div class="w-full h-full flex items-center justify-center text-slate-300">
                            <i class="fa-solid fa-house text-2xl"></i>
                        </div>
                    {% endif %}
                </div>
                <div>
                    <h3 class="font-serif text-2xl text-dark mb-1">{{ bien.titre }}</h3>
                    <p class="text-sm font-bold text-slate-500"><i class="fa-solid fa-location-dot text-gold mr-2"></i>{{ bien.ville }}, {{ bien.quartier }}</p>
                    <p class="text-lg font-black text-indigo-600 mt-2">{{ bien.prix|number_format(0, ',', ' ') }} GNF</p>
                </div>
            </div>

            {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
                
                {% if not form.vars.valid %}
                    <div class="bg-rose-50 text-rose-600 p-4 rounded-xl text-xs font-bold mb-6">
                        {{ form_errors(form) }}
                    </div>
                {% endif %}

                <div>
                    <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Date et Heure souhaitées</label>
                    {{ form_widget(form.dateVisite, {'attr': {'class': 'w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/20 transition-all'}}) }}
                    {{ form_errors(form.dateVisite, {'attr': {'class': 'text-rose-500 text-[10px] font-bold mt-1'}}) }}
                </div>

                <div>
                    <label class="block text-xs font-black uppercase tracking-widest text-slate-400 mb-2">Commentaire ou questions (optionnel)</label>
                    {{ form_widget(form.commentaire, {'attr': {'class': 'w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-bold focus:outline-none focus:border-indigo-600 focus:ring-2 focus:ring-indigo-600/20 transition-all resize-none', 'rows': '4', 'placeholder': 'Précisez vos disponibilités ou questions particulières...'}}) }}
                    {{ form_errors(form.commentaire, {'attr': {'class': 'text-rose-500 text-[10px] font-bold mt-1'}}) }}
                </div>

                <div class="pt-6">
                    <button type="submit" class="w-full flex items-center justify-center py-4 bg-indigo-600 text-white rounded-xl text-sm font-black uppercase tracking-widest hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-600/30">
                        <i class="fa-solid fa-paper-plane mr-2"></i> Envoyer la demande
                    </button>
                    <p class="text-[10px] text-center text-slate-400 mt-4 font-bold">L'agent immobilier vous contactera pour confirmer le rendez-vous.</p>
                </div>

            {{ form_end(form) }}

        </div>

    </div>
</div>
{% endblock %}
