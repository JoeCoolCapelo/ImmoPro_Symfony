{% extends 'base.html.twig' %}

{% block title %}Mes Rendez-vous & Visites - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <div class="bg-dark pt-16 pb-12 relative overflow-hidden">
        <div class="absolute inset-0 z-0 opacity-20">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=80&w=2000" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-dark to-transparent"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-10">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <a href="{{ path('app_home') }}" data-aos="fade-right" class="mr-4 w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white/80 hover:text-white hover:bg-white/20 hover:scale-105 transition-all shadow-lg">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <h2 data-aos="fade-left" data-aos-delay="100" class="font-black text-3xl md:text-5xl text-white leading-tight">
                        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_AGENT') %}
                            Gestion des Visites
                        {% elseif is_granted('ROLE_PROPRIETAIRE') %}
                            Visites de mes Biens
                        {% else %}
                            Mes Demandes de Visite
                        {% endif %}
                    </h2>
                </div>
                {# Seuls les admins et agents peuvent voir un résumé rapide #}
                {% if is_granted('ROLE_AGENT') %}
                    <div data-aos="fade-left" data-aos-delay="200" class="hidden md:flex items-center gap-3">
                        <span class="px-4 py-2 bg-amber-500/20 text-amber-300 border border-amber-500/30 rounded-xl text-[10px] font-black uppercase tracking-widest">
                            <i class="fa-solid fa-clock mr-1"></i> En attente
                        </span>
                        <span class="px-4 py-2 bg-indigo-500/20 text-indigo-300 border border-indigo-500/30 rounded-xl text-[10px] font-black uppercase tracking-widest">
                            <i class="fa-solid fa-check mr-1"></i> Confirmées
                        </span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="py-8 bg-slate-50/50 min-h-screen">
    <div class="max-w-7xl mx-auto sm:px-6 lg:px-8">
        
        {# Barre de Recherche et de Filtrage #}
        <div data-aos="fade-up" data-aos-delay="200" class="mb-8">
            <form action="{{ path('visites.index') }}" method="GET" class="flex flex-col md:flex-row gap-4">
                <!-- Recherche par mot-clé -->
                <div class="relative flex-1">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fa-solid fa-magnifying-glass text-slate-400"></i>
                    </div>
                    <input type="text" name="search" value="{{ app.request.query.get('search') }}" 
                        placeholder="Rechercher par titre du bien ou ville..." 
                        class="block w-full pl-12 pr-4 py-4 bg-white border-none rounded-[1.5rem] shadow-sm text-sm font-bold text-slate-700 focus:ring-2 focus:ring-indigo-500 transition-all">
                </div>

                <!-- Filtrage par statut -->
                <div class="relative min-w-[200px]">
                    <select name="statut" class="block w-full px-6 py-4 bg-white border-none rounded-[1.5rem] shadow-sm text-sm font-bold text-slate-700 focus:ring-2 focus:ring-indigo-500 transition-all cursor-pointer">
                        <option value="">Tous les statuts</option>
                        <option value="en_attente" {% if app.request.query.get('statut') == 'en_attente' %}selected{% endif %}>En attente</option>
                        <option value="confirmée" {% if app.request.query.get('statut') == 'confirmée' %}selected{% endif %}>Confirmée</option>
                        <option value="effectuée" {% if app.request.query.get('statut') == 'effectuée' %}selected{% endif %}>Effectuée</option>
                        <option value="annulée" {% if app.request.query.get('statut') == 'annulée' %}selected{% endif %}>Annulée</option>
                        <option value="finalisée" {% if app.request.query.get('statut') == 'finalisée' %}selected{% endif %}>Finalisée</option>
                    </select>
                </div>

                <!-- Boutons de soumission et effacement -->
                <div class="flex gap-2">
                    <button type="submit" class="px-8 py-4 bg-slate-900 text-white rounded-[1.5rem] text-xs font-black uppercase tracking-widest hover:bg-slate-800 transition-all shadow-lg">
                        Filtrer
                    </button>
                    {% if app.request.query.get('search') or app.request.query.get('statut') %}
                        <a href="{{ path('visites.index') }}" class="px-6 py-4 bg-white text-slate-500 rounded-[1.5rem] text-xs font-black uppercase tracking-widest hover:bg-slate-100 transition-all flex items-center shadow-sm">
                            Effacer
                        </a>
                    {% endif %}
                </div>
            </form>
        </div>

        {% if visites is empty %}
            <div class="premium-card p-12 text-center bg-white">
                <h3 class="text-xl font-bold text-slate-900">Aucune visite planifiée</h3>
            </div>
        {% else %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {% for visite in visites %}
                    <div data-aos="fade-up" data-aos-delay="{{ loop.index0 * 100 }}" class="premium-card overflow-hidden flex flex-col h-full group bg-white">
                        <div class="h-48 relative overflow-hidden bg-slate-900">
                            {% if visite.bien and visite.bien.images|length > 0 %}
                                <img src="{{ asset(visite.bien.images[0].path) }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
                            {% else %}
                                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-indigo-500 to-violet-600">
                                    <i class="fa-solid fa-calendar-check text-5xl text-white/20"></i>
                                </div>
                            {% endif %}
                            <div class="absolute top-4 right-4">
                                {% set statusClasses = {
                                    'en_attente': 'bg-amber-500 text-white',
                                    'confirmée': 'bg-indigo-600 text-white',
                                    'effectuée': 'bg-emerald-500 text-white',
                                    'annulée': 'bg-rose-500 text-white',
                                    'finalisée': 'bg-emerald-600 text-white',
                                } %}
                                <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest shadow-lg {{ statusClasses[visite.statut]|default('bg-slate-500 text-white') }}">
                                    {{ visite.statut }}
                                </span>
                            </div>
                        </div>

                        <div class="p-6 flex-1 flex flex-col">
                            <h4 class="text-lg font-black text-slate-900 mb-1 truncate">
                                {% if visite.bien %}
                                    <a href="{{ path('biens.show', {id: visite.bien.id}) }}" class="hover:text-indigo-600 transition-colors">
                                        {{ visite.bien.titre }}
                                    </a>
                                {% else %}
                                    <span class="text-rose-500 italic">Propriété supprimée</span>
                                {% endif %}
                            </h4>

                            <div class="space-y-3 mb-6 mt-4">
                                <div class="flex items-center p-3 bg-slate-50 rounded-2xl border border-slate-100">
                                    <div class="h-10 w-10 bg-white rounded-xl flex items-center justify-center text-indigo-600 shadow-sm mr-4">
                                        <i class="fa-solid fa-calendar"></i>
                                    </div>
                                    <div>
                                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Date & Heure</p>
                                        <p class="text-xs font-black text-slate-900">{{ visite.dateVisite|date('d F Y') }} — {{ visite.dateVisite|date('H:i') }}</p>
                                    </div>
                                </div>
                            </div>

                            {# ===== ACTIONS PAR RÔLE ===== #}
                            <div class="mt-auto pt-6 border-t border-slate-50 flex items-center justify-between gap-2">

                                {# AGENT: Peut confirmer, marquer effectuée, annuler #}
                                {% if is_granted('VISITE_VALIDATE', visite) %}
                                    <div class="flex flex-wrap items-center gap-2">
                                        {% if visite.statut == 'en_attente' %}
                                            <form method="POST" action="{{ path('visites.update', {id: visite.id}) }}">
                                                <input type="hidden" name="statut" value="confirmée">
                                                <button type="submit" class="px-3 py-2 bg-indigo-600 text-white rounded-xl text-[10px] font-black uppercase tracking-wider hover:bg-indigo-700 transition shadow-sm">
                                                    <i class="fa-solid fa-check mr-1"></i> Confirmer
                                                </button>
                                            </form>
                                        {% elseif visite.statut == 'confirmée' %}
                                            <form method="POST" action="{{ path('visites.update', {id: visite.id}) }}">
                                                <input type="hidden" name="statut" value="effectuée">
                                                <button type="submit" class="px-3 py-2 bg-emerald-500 text-white rounded-xl text-[10px] font-black uppercase tracking-wider hover:bg-emerald-600 transition shadow-sm">
                                                    <i class="fa-solid fa-calendar-check mr-1"></i> Effectuée
                                                </button>
                                            </form>
                                        {% endif %}
                                        {% if visite.statut not in ['annulée', 'finalisée', 'effectuée'] %}
                                            <form method="POST" action="{{ path('visites.update', {id: visite.id}) }}">
                                                <input type="hidden" name="statut" value="annulée">
                                                <button type="submit" class="px-3 py-2 bg-rose-50 text-rose-500 hover:bg-rose-500 hover:text-white rounded-xl text-[10px] font-black uppercase tracking-wider transition shadow-sm">
                                                    <i class="fa-solid fa-ban mr-1"></i> Annuler
                                                </button>
                                            </form>
                                        {% endif %}
                                    </div>

                                {# PROPRIETAIRE: Lecture seule avec info de statut #}
                                {% elseif is_granted('ROLE_PROPRIETAIRE') %}
                                    <div class="text-xs text-slate-400 italic">Vue en lecture seule</div>

                                {# CLIENT: Peut seulement annuler sa propre demande #}
                                {% elseif is_granted('VISITE_DELETE', visite) %}
                                    <div></div>
                                {% endif %}

                                {# Bouton Supprimer : uniquement pour le client propriétaire de la demande #}
                                <div class="flex items-center space-x-2">
                                    <a href="{{ path('visites.show', {id: visite.id}) }}" class="h-10 px-4 flex items-center justify-center bg-slate-50 text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 rounded-xl transition-all shadow-sm text-[10px] font-black uppercase">
                                        <i class="fa-solid fa-eye mr-1"></i> Détails
                                    </a>
                                    {% if is_granted('VISITE_DELETE', visite) and visite.statut not in ['confirmée', 'effectuée', 'finalisée'] %}
                                        <form method="POST" action="{{ path('visites.destroy', {id: visite.id}) }}" onsubmit="return confirm('Annuler cette demande de visite ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ visite.id) }}">
                                            <button type="submit" class="h-10 w-10 flex items-center justify-center bg-rose-50 text-rose-500 hover:bg-rose-500 hover:text-white rounded-xl transition-all shadow-sm">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
            
            <div class="mt-10">
                {{ knp_pagination_render(visites) }}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
