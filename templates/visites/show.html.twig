{% extends 'base.html.twig' %}

{% block title %}Détails de la Visite - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <div class="bg-dark pt-16 pb-24 relative overflow-hidden">
        <div class="absolute inset-0 z-0 opacity-20">
            {% if visite.bien and visite.bien.image %}
                <img src="{{ asset('uploads/' ~ visite.bien.image) }}" class="w-full h-full object-cover">
            {% else %}
                <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=2000" class="w-full h-full object-cover">
            {% endif %}
            <div class="absolute inset-0 bg-gradient-to-t from-dark to-transparent"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-10">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
                <div class="flex items-center">
                    <a href="{{ path('visites.index') }}" class="mr-4 w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white/80 hover:text-white hover:bg-white/20 hover:scale-105 transition-all shadow-lg">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <div>
                        <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest bg-indigo-500/20 text-indigo-300 border border-indigo-500/30 mb-2 inline-block">
                            Réf #VI-{{ visite.id|format("%04d") }}
                        </span>
                        <h2 class="font-serif text-3xl md:text-5xl text-white leading-tight">
                            Détails de la <span class="italic text-indigo-400">Visite</span>
                        </h2>
                    </div>
                </div>
                
                {# Étiquette de Statut Actuel #}
                {% set statusColors = {
                    'en_attente': 'bg-amber-500/10 text-amber-400 border border-amber-500/20',
                    'confirmée': 'bg-indigo-500/10 text-indigo-400 border border-indigo-500/20',
                    'effectuée': 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20',
                    'annulée': 'bg-rose-500/10 text-rose-400 border border-rose-500/20',
                    'finalisée': 'bg-slate-500/10 text-slate-400 border border-slate-500/20'
                } %}
                <div class="shrink-0">
                    <span class="px-5 py-2.5 rounded-2xl text-xs font-black uppercase tracking-widest shadow-xl {{ statusColors[visite.statut]|default('bg-slate-500/10 text-slate-400') }}">
                        <i class="fa-solid fa-circle-dot mr-2 animate-pulse text-[9px]"></i> {{ visite.statut }}
                    </span>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="py-8 bg-slate-50 min-h-screen -mt-16 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {# Notifications / Messages Flash #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-8 p-4 rounded-2xl {% if label == 'success' %}bg-emerald-50 text-emerald-800 border border-emerald-100{% else %}bg-rose-50 text-rose-800 border border-rose-100{% endif %} flex items-center shadow-sm">
                    <i class="fa-solid {% if label == 'success' %}fa-circle-check text-emerald-500{% else %}fa-circle-xmark text-rose-500{% endif %} mr-3 text-lg"></i>
                    <span class="font-bold text-sm">{{ message }}</span>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            {# ================= COLONNE GAUCHE & CENTRE : INFOS PRINCIPALES ================= #}
            <div class="lg:col-span-2 space-y-8">
                
                {# Étape du Workflow #}
                <div class="premium-card p-6 bg-white shadow-sm">
                    <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-6">Suivi de la demande</h3>
                    <div class="relative flex items-center justify-between">
                        {# Ligne de progression arrière plan #}
                        <div class="absolute left-0 right-0 top-1/2 -translate-y-1/2 h-1 bg-slate-100 rounded z-0"></div>
                        
                        {# Étapes #}
                        {% set steps = [
                            {'id': 'en_attente', 'label': 'Soumise', 'icon': 'fa-paper-plane'},
                            {'id': 'confirmée', 'label': 'Confirmée', 'icon': 'fa-calendar-check'},
                            {'id': 'effectuée', 'label': 'Effectuée', 'icon': 'fa-eye'},
                            {'id': 'finalisée', 'label': 'Terminée', 'icon': 'fa-flag-checkered'}
                        ] %}
                        
                        {% set currentStepIndex = 0 %}
                        {% if visite.statut == 'confirmée' %}{% set currentStepIndex = 1 %}
                        {% elseif visite.statut == 'effectuée' %}{% set currentStepIndex = 2 %}
                        {% elseif visite.statut == 'finalisée' %}{% set currentStepIndex = 3 %}
                        {% elseif visite.statut == 'annulée' %}{% set currentStepIndex = -1 %}{% endif %}

                        {% for step in steps %}
                            {% set isCompleted = currentStepIndex >= loop.index0 %}
                            {% set isActive = visite.statut == step.id %}
                            
                            <div class="flex flex-col items-center relative z-10">
                                <div class="w-12 h-12 rounded-full flex items-center justify-center border-2 transition-all duration-300
                                    {% if isActive %}
                                        bg-indigo-600 border-indigo-600 text-white shadow-lg shadow-indigo-600/30 scale-110
                                    {% elseif isCompleted %}
                                        bg-emerald-500 border-emerald-500 text-white
                                    {% else %}
                                        bg-white border-slate-200 text-slate-400
                                    {% endif %}">
                                    <i class="fa-solid {{ step.icon }} text-xs"></i>
                                </div>
                                <span class="text-[10px] font-black uppercase tracking-widest mt-2 
                                    {% if isActive %}text-indigo-600{% elseif isCompleted %}text-slate-900{% else %}text-slate-400{% endif %}">
                                    {{ step.label }}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {# Infos Propriété / Bien #}
                {% if visite.bien %}
                    <div class="premium-card overflow-hidden bg-white shadow-sm">
                        <div class="h-64 relative">
                            {% if visite.bien.image %}
                                <img src="{{ asset('uploads/' ~ visite.bien.image) }}" class="w-full h-full object-cover">
                            {% else %}
                                <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80&w=2000" class="w-full h-full object-cover">
                            {% endif %}
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                            <div class="absolute bottom-6 left-6 right-6 text-white">
                                <span class="px-2.5 py-1 rounded-md text-[9px] font-black uppercase tracking-widest bg-white/20 backdrop-blur-md border border-white/20 mb-2 inline-block">
                                    {{ visite.bien.nature == 'vente' ? 'À vendre' : 'En location' }}
                                </span>
                                <h3 class="font-serif text-2xl font-bold">{{ visite.bien.titre }}</h3>
                                <p class="text-xs text-white/80 mt-1"><i class="fa-solid fa-location-dot mr-1"></i> {{ visite.bien.adresse }}, {{ visite.bien.ville }}</p>
                            </div>
                        </div>
                        <div class="p-6 grid grid-cols-2 sm:grid-cols-4 gap-6 bg-white border-t border-slate-100">
                            <div>
                                <span class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Prix demandés</span>
                                <span class="text-lg font-black text-indigo-600">{{ visite.bien.prix|number_format(0, ',', ' ') }} GNF</span>
                            </div>
                            <div>
                                <span class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Type de bien</span>
                                <span class="text-sm font-bold text-slate-700 capitalize">{{ visite.bien.type }}</span>
                            </div>
                            <div>
                                <span class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Surface</span>
                                <span class="text-sm font-bold text-slate-700">{{ visite.bien.surface }} m²</span>
                            </div>
                            <div>
                                <span class="block text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Pièces</span>
                                <span class="text-sm font-bold text-slate-700">{{ visite.bien.nbPieces|default('N/A') }} pièces</span>
                            </div>
                        </div>
                    </div>
                {% endif %}

                {# Infos Date & Heure de rendez-vous #}
                <div class="premium-card p-6 bg-white shadow-sm">
                    <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4">Date & Heure du Rendez-vous</h3>
                    <div class="flex items-center p-4 bg-slate-50 border border-slate-100 rounded-2xl">
                        <div class="h-12 w-12 bg-indigo-600 rounded-xl flex items-center justify-center text-white shadow-lg shadow-indigo-600/20 mr-4 shrink-0">
                            <i class="fa-solid fa-calendar-days text-lg"></i>
                        </div>
                        <div>
                            <p class="text-sm font-black text-slate-900">
                                {{ visite.dateVisite|date('d F Y') }} — À {{ visite.dateVisite|date('H:i') }}
                            </p>
                            <p class="text-[11px] font-bold text-slate-400 mt-0.5">
                                Fuseau horaire : Local (Afrique/Conakry)
                            </p>
                        </div>
                    </div>
                </div>

                {# Notes et Feedbacks #}
                <div class="premium-card p-6 bg-white shadow-sm space-y-6">
                    <div>
                        <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2">Commentaire du client</h3>
                        <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100 text-xs font-medium text-slate-600 italic">
                            "{{ visite.commentaire|default('Aucun commentaire fourni par le client.') }}"
                        </div>
                    </div>

                    {% if visite.feedbackAgent %}
                        <div>
                            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2">Rapport d'évaluation de l'agent</h3>
                            <div class="p-4 bg-indigo-50/50 rounded-2xl border border-indigo-100/50 text-xs font-medium text-slate-700">
                                <div class="flex items-center text-indigo-700 font-black mb-2 uppercase tracking-wider text-[9px]">
                                    <i class="fa-solid fa-clipboard-user mr-2"></i> Feedback commercial de l'agent
                                </div>
                                "{{ visite.feedbackAgent }}"
                            </div>
                        </div>
                    {% endif %}
                </div>

            </div>

            {# ================= COLONNE DROITE : ACTEURS & ACTIONS RAPIDES ================= #}
            <div class="space-y-8">
                
                {# Parties Prenantes #}
                <div class="premium-card p-6 bg-white shadow-sm space-y-6">
                    <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2">Acteurs concernés</h3>
                    
                    {# Client #}
                    {% if visite.client %}
                        <div class="flex items-center p-3 hover:bg-slate-50 rounded-2xl transition-all border border-slate-100">
                            <div class="h-10 w-10 bg-slate-900 rounded-xl flex items-center justify-center text-white font-black text-sm shrink-0">
                                {{ visite.client.name|slice(0, 1)|upper }}
                            </div>
                            <div class="ms-3 overflow-hidden">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Client demandeur</p>
                                <p class="text-xs font-black text-slate-900 truncate">{{ visite.client.name }}</p>
                                <p class="text-[10px] font-bold text-slate-400 truncate">{{ visite.client.email }}</p>
                            </div>
                        </div>
                    {% endif %}

                    {# Agent #}
                    {% if visite.bien and visite.bien.agent %}
                        <div class="flex items-center p-3 hover:bg-slate-50 rounded-2xl transition-all border border-slate-100">
                            <div class="h-10 w-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white font-black text-sm shrink-0">
                                {{ visite.bien.agent.name|slice(0, 1)|upper }}
                            </div>
                            <div class="ms-3 overflow-hidden">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Agent Responsable</p>
                                <p class="text-xs font-black text-slate-900 truncate">{{ visite.bien.agent.name }}</p>
                                <p class="text-[10px] font-bold text-slate-400 truncate">{{ visite.bien.agent.email }}</p>
                            </div>
                        </div>
                    {% endif %}

                    {# Propriétaire #}
                    {% if visite.bien and visite.bien.owner %}
                        <div class="flex items-center p-3 hover:bg-slate-50 rounded-2xl transition-all border border-slate-100">
                            <div class="h-10 w-10 bg-slate-100 rounded-xl flex items-center justify-center text-slate-700 font-black text-sm shrink-0">
                                {{ visite.bien.owner.name|slice(0, 1)|upper }}
                            </div>
                            <div class="ms-3 overflow-hidden">
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Propriétaire du bien</p>
                                <p class="text-xs font-black text-slate-900 truncate">{{ visite.bien.owner.name }}</p>
                                <p class="text-[10px] font-bold text-slate-400 truncate">{{ visite.bien.owner.email }}</p>
                            </div>
                        </div>
                    {% endif %}
                </div>

                {# Actions de modification / Feedback pour l'Agent ou Admin #}
                {% if is_granted('VISITE_VALIDATE', visite) %}
                    <div class="premium-card p-6 bg-white shadow-sm space-y-4">
                        <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest">Gestion Commerciale (Agent)</h3>
                        
                        <form method="POST" action="{{ path('visites.update', {id: visite.id}) }}" class="space-y-4">
                            <div>
                                <label for="feedback_agent" class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Feedback de l'agent (Rapport)</label>
                                <textarea name="feedback_agent" id="feedback_agent" rows="4" class="block w-full rounded-xl border-slate-200 bg-slate-50 focus:border-indigo-500 focus:ring-0 transition-colors text-xs font-bold text-slate-700 py-3" 
                                    placeholder="Racontez le déroulement de la visite, les réactions du client...">{{ visite.feedbackAgent }}</textarea>
                            </div>

                            <button type="submit" class="btn-premium w-full flex items-center justify-center py-3">
                                <i class="fa-solid fa-floppy-disk mr-2"></i> Enregistrer les modifications
                            </button>
                        </form>

                        {# Bouton d'initiation de la transaction #}
                        {% if visite.statut == 'effectuée' and visite.isInterested == true and visite.bien and visite.bien.statut in ['publié', 'en_attente'] %}
                            <div class="pt-4 border-t border-slate-100 mt-4">
                                <a href="{{ path('transactions.create', {bien_id: visite.bien.id, user_id: visite.client.id, visite_id: visite.id}) }}" class="w-full h-12 bg-emerald-600 text-white rounded-xl text-xs font-black uppercase tracking-widest hover:bg-emerald-700 transition flex items-center justify-center shadow-lg shadow-emerald-600/20">
                                    <i class="fa-solid fa-file-signature mr-2 text-base"></i> Créer une transaction
                                </a>
                            </div>
                        {% endif %}
                    </div>
                {% endif %}

                {# Avis d'Intérêt du Client #}
                {% if app.user == visite.client and visite.statut == 'effectuée' %}
                    <div class="premium-card p-6 bg-white shadow-sm space-y-4">
                        <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest">Votre avis nous intéresse</h3>
                        <p class="text-xs font-bold text-slate-500 leading-relaxed">
                            Maintenant que la visite est terminée, êtes-vous intéressé par cette propriété ? Votre réponse sera directement partagée avec le propriétaire.
                        </p>
                        
                        <div class="flex flex-col gap-2 pt-2">
                            <form method="POST" action="{{ path('visites.update', {id: visite.id}) }}">
                                <input type="hidden" name="interested" value="true">
                                <button type="submit" class="w-full py-3 rounded-xl font-black text-xs uppercase tracking-widest border transition-all flex items-center justify-center gap-2
                                    {% if visite.isInterested == true %}
                                        bg-emerald-50 border-emerald-300 text-emerald-700 shadow-md shadow-emerald-500/5
                                    {% else %}
                                        bg-white border-slate-200 text-slate-600 hover:bg-slate-50
                                    {% endif %}">
                                    <i class="fa-solid fa-circle-check text-base"></i> Je suis intéressé !
                                </button>
                            </form>

                            <form method="POST" action="{{ path('visites.update', {id: visite.id}) }}">
                                <input type="hidden" name="interested" value="false">
                                <button type="submit" class="w-full py-3 rounded-xl font-black text-xs uppercase tracking-widest border transition-all flex items-center justify-center gap-2
                                    {% if visite.isInterested == false and visite.isInterested is not null %}
                                        bg-rose-50 border-rose-300 text-rose-700 shadow-md shadow-rose-500/5
                                    {% else %}
                                        bg-white border-slate-200 text-slate-600 hover:bg-slate-50
                                    {% endif %}">
                                    <i class="fa-solid fa-circle-xmark text-base"></i> Pas intéressé
                                </button>
                            </form>
                        </div>
                    </div>
                {% endif %}

                {# Annuler la Demande pour le Client #}
                {% if app.user == visite.client and visite.statut == 'en_attente' %}
                    <div class="premium-card p-6 bg-white shadow-sm space-y-4">
                        <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest">Annuler la demande</h3>
                        <p class="text-xs font-bold text-slate-500">Vous pouvez annuler votre demande de visite tant qu'elle n'a pas été confirmée par un agent.</p>
                        
                        <form method="POST" action="{{ path('visites.destroy', {id: visite.id}) }}" onsubmit="return confirm('Voulez-vous vraiment annuler votre demande de visite ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ visite.id) }}">
                            <button type="submit" class="w-full py-3 bg-rose-50 hover:bg-rose-500 hover:text-white border border-rose-100 text-rose-500 rounded-xl text-xs font-black uppercase tracking-widest transition-all">
                                <i class="fa-solid fa-ban mr-1"></i> Annuler la visite
                            </button>
                        </form>
                    </div>
                {% endif %}

            </div>

        </div>

    </div>
</div>
{% endblock %}
