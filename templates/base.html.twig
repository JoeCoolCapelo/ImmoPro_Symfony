<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ global_settings.agency_name|default('ImmoPro Premium') }}{% endblock %}</title>

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,700&display=swap" rel="stylesheet">
        
        <!-- Icons -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
        
        <!-- Animations -->
        <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
        
        <!-- Frameworks -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <script src="https://cdn.tailwindcss.com"></script>
        <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

        <script>
            tailwind.config = {
                darkMode: 'class',
                theme: {
                    extend: {
                        colors: {
                            premium: '#2563EB',
                            dark: '#0F172A',
                            gold: '#D4AF37',
                            slate: { 
                                50: '#F8FAFC',
                                950: '#020617',
                            }
                        },
                        fontFamily: {
                            sans: ['Inter', 'sans-serif'],
                            serif: ['Playfair Display', 'serif'],
                        }
                    }
                }
            }
        </script>

        <style>
            :root {
                --premium-blue: #2563EB;
                --modern-black: #0F172A;
                --gold-accent: #D4AF37;
            }
            
            body { 
                font-family: 'Inter', sans-serif; 
                background-color: #F8FAFC; 
                color: #0F172A;
                -webkit-font-smoothing: antialiased;
                font-weight: 600;
            }

            *, *::before, *::after {
                font-weight: inherit;
            }

            .font-serif { font-family: 'Playfair Display', serif; }
            
            h1, h2, h3, h4, h5, h6, .font-serif, [class*="font-serif"] {
                font-weight: 900 !important;
            }
            
            /* UI Components */
            .glass { 
                background: rgba(255, 255, 255, 0.7); 
                backdrop-filter: blur(20px); 
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid rgba(255, 255, 255, 0.3); 
            }
            
            .premium-card { 
                background: white;
                border-radius: 2rem;
                border: 1px solid rgba(15, 23, 42, 0.05);
                box-shadow: 0 10px 40px -10px rgba(15, 23, 42, 0.05);
                transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .premium-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 30px 60px -12px rgba(15, 23, 42, 0.12);
            }

            .btn-premium { 
                background: var(--modern-black); 
                color: white; 
                border-radius: 1rem; 
                padding: 0.8rem 2rem; 
                font-weight: 800; 
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 0.1em;
                transition: all 0.3s; 
                border: none;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }

            .btn-premium:hover { 
                background: var(--premium-blue); 
                transform: scale(1.05);
                box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2); 
                color: white;
            }

            /* Animations */
            @keyframes blob {
                0% { transform: translate(0px, 0px) scale(1); }
                33% { transform: translate(30px, -50px) scale(1.1); }
                66% { transform: translate(-20px, 20px) scale(0.9); }
                100% { transform: translate(0px, 0px) scale(1); }
            }
            .animate-blob { animation: blob 7s infinite; }
            .animation-delay-2000 { animation-delay: 2s; }
            .animation-delay-4000 { animation-delay: 4s; }

            /* Scrollbar */
            ::-webkit-scrollbar { width: 6px; }
            ::-webkit-scrollbar-track { background: #f1f1f1; }
            ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
            ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

            /* ===== Premium Pagination ===== */
            .pagination {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 0.375rem;
                list-style: none;
                padding: 0;
                margin: 0;
                flex-wrap: wrap;
            }
            .pagination li { display: inline-flex; }
            .pagination li a,
            .pagination li span {
                display: flex;
                align-items: center;
                justify-content: center;
                min-width: 2.75rem;
                height: 2.75rem;
                padding: 0 0.75rem;
                border-radius: 0.875rem;
                font-size: 0.8rem;
                font-weight: 800;
                text-decoration: none;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                border: 1.5px solid #e2e8f0;
                background: white;
                color: #475569;
            }
            .pagination li a:hover {
                background: var(--premium-blue);
                color: white;
                border-color: var(--premium-blue);
                box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.3);
                transform: scale(1.08);
            }
            .pagination li.active span,
            .pagination li .current {
                background: var(--premium-blue);
                color: white;
                border-color: var(--premium-blue);
                box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.35);
                transform: scale(1.05);
            }
            .pagination li.disabled span,
            .pagination li.disabled a {
                background: #f8fafc;
                color: #cbd5e1;
                border-color: #f1f5f9;
                cursor: not-allowed;
                pointer-events: none;
            }
            .pagination li:first-child a,
            .pagination li:first-child span,
            .pagination li:last-child a,
            .pagination li:last-child span {
                padding: 0 1.25rem;
                border-radius: 1rem;
                font-size: 0.7rem;
                font-weight: 900;
                text-transform: uppercase;
                letter-spacing: 0.1em;
            }
        </style>
        
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="selection:bg-indigo-100 selection:text-indigo-900">
        {% include 'components/_navbar.html.twig' %}
        
        {% block header %}{% endblock %}

        <main>
            {% block content %}{% endblock %}
        </main>

        {% include 'components/_footer.html.twig' %}
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                AOS.init({
                    duration: 800,
                    once: true,
                    offset: 50,
                });
            });
        </script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
