{% extends 'base.html.twig' %}

{% block title %}Mes Documents - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <div class="bg-dark pt-16 pb-12 relative overflow-hidden">
        <div class="absolute inset-0 z-0 opacity-20">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&q=80&w=2000" class="w-full h-full object-cover">
            <div class="absolute inset-0 bg-gradient-to-t from-dark to-transparent"></div>
        </div>
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 mt-10">
            <div class="flex justify-between items-center">
                <div class="flex items-center">
                    <a href="{{ path('app_home') }}" class="mr-4 w-12 h-12 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white/80 hover:text-white hover:bg-white/20 hover:scale-105 transition-all shadow-lg">
                        <i class="fa-solid fa-arrow-left"></i>
                    </a>
                    <h2 class="font-black text-3xl md:text-5xl text-white leading-tight">
                        Gestion des Documents
                    </h2>
                </div>
            <div class="flex space-x-3">
                <span class="px-4 py-2 bg-white/10 backdrop-blur-md rounded-2xl text-[10px] font-black text-white uppercase tracking-widest border border-white/10 shadow-sm">
                    {{ documents.getTotalItemCount }} Fichiers
                </span>
            </div>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="py-8 bg-slate-50/50 min-h-screen">
    <div class="max-w-7xl mx-auto sm:px-6 lg:px-8">
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {% for document in documents %}
                <div class="premium-card bg-white p-6 group hover:scale-[1.02] transition-all duration-300">
                    <div class="flex justify-between items-start mb-6">
                        <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center group-hover:bg-indigo-600 group-hover:text-white transition-colors duration-300">
                            {% if document.type == 'contrat' %}
                                <i class="fa-solid fa-file-signature text-xl"></i>
                            {% elseif document.type == 'facture' %}
                                <i class="fa-solid fa-file-invoice-dollar text-xl"></i>
                            {% else %}
                                <i class="fa-solid fa-file-lines text-xl"></i>
                            {% endif %}
                        </div>
                        <div class="flex flex-col items-end">
                            <span class="px-2 py-0.5 bg-slate-100 text-slate-600 rounded text-[8px] font-black uppercase mb-1">
                                {{ document.type }}
                            </span>
                            <span class="text-[9px] text-slate-400 font-bold uppercase tracking-tighter">
                                {{ document.createdAt|date('d M Y') }}
                            </span>
                        </div>
                    </div>

                    <h3 class="font-bold text-slate-900 text-sm mb-1 truncate" title="{{ document.nom }}">
                        {{ document.nom }}
                    </h3>
                    <p class="text-[10px] text-slate-400 font-medium mb-6">
                        {% if document.bien %}
                            Bien : {{ document.bien.titre|slice(0, 30) }}...
                        {% else %}
                            Document administratif
                        {% endif %}
                    </p>

                    <div class="flex items-center justify-between pt-4 border-t border-slate-50">
                        <a href="{{ path('documents.download', {id: document.id}) }}" class="flex items-center text-[10px] font-black text-indigo-600 uppercase tracking-widest hover:text-indigo-800 transition-colors">
                            <i class="fa-solid fa-download mr-2"></i> Télécharger
                        </a>
                        <div class="flex space-x-1">
                            <button class="p-2 text-slate-400 hover:text-rose-500 transition-colors">
                                <i class="fa-solid fa-trash-can text-xs"></i>
                            </button>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-span-full py-20 text-center">
                    <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="fa-solid fa-folder-open text-3xl text-slate-300"></i>
                    </div>
                    <h3 class="font-bold text-slate-900 mb-1">Aucun document</h3>
                    <p class="text-sm text-slate-500">Les contrats et factures s'afficheront ici.</p>
                </div>
            {% endfor %}
        </div>

        {# Pagination #}
        <div class="mt-10">
            {{ knp_pagination_render(documents) }}
        </div>

    </div>
</div>
{% endblock %}
