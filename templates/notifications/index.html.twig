{% extends 'base.html.twig' %}

{% block title %}Mes Notifications - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 flex justify-between items-center">
        <h2 class="font-black text-xl text-white leading-tight">
            Centre de Notifications
        </h2>
        {% if notifications|filter(n => not n.isRead)|length > 0 %}
            <form action="{{ path('notifications.read_all') }}" method="POST">
                <button type="submit" class="px-5 py-2 bg-white/10 hover:bg-white/20 text-white rounded-xl text-xs font-black uppercase tracking-widest transition-all">
                    <i class="fa-solid fa-check-double mr-2"></i> Tout marquer comme lu
                </button>
            </form>
        {% endif %}
    </div>
{% endblock %}

{% block content %}
<div class="py-8 bg-slate-50/50 min-h-screen">
    <div class="max-w-4xl mx-auto sm:px-6 lg:px-8">
        
        <div class="premium-card bg-white p-8">
            {% if notifications is empty %}
                <div class="text-center py-16">
                    <div class="w-20 h-20 bg-indigo-50 text-indigo-500 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner">
                        <i class="fa-solid fa-bell-slash text-3xl"></i>
                    </div>
                    <h3 class="font-black text-slate-800 text-lg">Aucune notification</h3>
                    <p class="text-xs text-slate-400 mt-2">Vous êtes parfaitement à jour ! Toutes les nouvelles activités s'afficheront ici.</p>
                </div>
            {% else %}
                <div class="divide-y divide-slate-100">
                    {% for notification in notifications %}
                        <div class="py-5 flex gap-4 transition-all {{ not notification.isRead ? 'bg-indigo-50/30 -mx-4 px-4 rounded-2xl' : '' }}">
                            {# Icon column based on type #}
                            <div class="flex-shrink-0">
                                {% if notification.type == 'visite' %}
                                    <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center shadow-sm">
                                        <i class="fa-solid fa-calendar-check text-base"></i>
                                    </div>
                                {% elseif notification.type == 'transaction' %}
                                    <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center shadow-sm">
                                        <i class="fa-solid fa-receipt text-base"></i>
                                    </div>
                                {% elseif notification.type == 'paiement' %}
                                    <div class="w-10 h-10 bg-emerald-100 text-emerald-600 rounded-xl flex items-center justify-center shadow-sm">
                                        <i class="fa-solid fa-wallet text-base"></i>
                                    </div>
                                {% else %}
                                    <div class="w-10 h-10 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center shadow-sm">
                                        <i class="fa-solid fa-bell text-base"></i>
                                    </div>
                                {% endif %}
                            </div>

                            {# Text column #}
                            <div class="flex-grow">
                                <div class="flex items-start justify-between">
                                    <div>
                                        <h4 class="font-bold text-sm text-slate-800 {{ not notification.isRead ? 'font-black' : '' }}">
                                            {{ notification.title }}
                                        </h4>
                                        <p class="text-xs text-slate-500 mt-1 leading-relaxed">
                                            {{ notification.message }}
                                        </p>
                                        <span class="text-[10px] text-slate-400 mt-2 block">
                                            {{ notification.createdAt|date('d/m/Y à H:i') }}
                                        </span>
                                    </div>
                                    
                                    {# Mark as read form #}
                                    {% if not notification.isRead %}
                                        <form action="{{ path('notifications.read', {'id': notification.id}) }}" method="POST" class="ml-4">
                                            <button type="submit" class="text-indigo-600 hover:text-indigo-800 text-[10px] font-black uppercase tracking-widest" title="Marquer comme lu">
                                                Lue
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}
