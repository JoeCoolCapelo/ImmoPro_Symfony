{% extends 'base.html.twig' %}

{% block title %}{{ bien.titre }} - {{ global_settings.agency_name|default('ImmoPro') }}{% endblock %}

{% block header %}
    <!-- Immersive Header Image -->
    <div class="relative h-[60vh] md:h-[80vh] w-full bg-dark overflow-hidden group">
        
        <!-- Back Button -->
        <a href="{{ path('biens.index') }}" class="absolute top-8 left-8 md:top-12 md:left-12 z-30 w-12 h-12 rounded-full bg-black/30 backdrop-blur-md border border-white/20 text-white flex items-center justify-center hover:bg-white/20 hover:scale-110 transition-all shadow-lg">
            <i class="fa-solid fa-arrow-left"></i>
        </a>

        <img src="{{ bien.image ? asset(bien.image) : 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9' }}" class="w-full h-full object-cover opacity-80 group-hover:scale-105 transition-transform duration-[2s]" alt="{{ bien.titre }}">
        <div class="absolute inset-0 bg-gradient-to-t from-slate-50 via-dark/20 to-transparent"></div>
        
        <div class="absolute bottom-0 left-0 w-full p-8 md:p-16 z-10">
            <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-end gap-6">
                <div class="max-w-3xl">
                    <div class="flex flex-wrap gap-3 mb-6">
                        <span data-aos="fade-down" class="px-4 py-1.5 bg-white/20 backdrop-blur-md text-white rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-white/30">
                            {{ bien.nature }}
                        </span>
                        {% if bien.statut == 'vendu' %}
                            <span data-aos="fade-down" data-aos-delay="50" class="px-4 py-1.5 bg-rose-500/80 backdrop-blur-md text-white rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-rose-400/50 shadow-lg flex items-center gap-2">
                                <i class="fa-solid fa-tag"></i> Acheté
                            </span>
                        {% elseif bien.statut == 'loué' %}
                            <span data-aos="fade-down" data-aos-delay="50" class="px-4 py-1.5 bg-indigo-500/80 backdrop-blur-md text-white rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-indigo-400/50 shadow-lg flex items-center gap-2">
                                <i class="fa-solid fa-key"></i> En Location
                            </span>
                        {% elseif bien.statut == 'suspendu' %}
                            <span data-aos="fade-down" data-aos-delay="50" class="px-4 py-1.5 bg-amber-500/80 backdrop-blur-md text-white rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-amber-400/50 shadow-lg flex items-center gap-2">
                                <i class="fa-solid fa-eye-slash"></i> Suspendu
                            </span>
                        {% endif %}
                        <span data-aos="fade-down" data-aos-delay="100" class="px-4 py-1.5 bg-dark/60 backdrop-blur-md text-white rounded-full text-[10px] font-black uppercase tracking-[0.2em] border border-white/10 flex items-center gap-2" title="Vues réelles des clients">
                            <i class="fa-regular fa-eye text-gold"></i> {{ bien.vues|default(0) }} vue(s)
                        </span>
                    </div>
                    <h1 data-aos="fade-up" data-aos-delay="100" class="text-4xl md:text-6xl font-serif text-white leading-tight mb-4 shadow-sm">{{ bien.titre }}</h1>
                    <p data-aos="fade-up" data-aos-delay="200" class="text-white/80 text-sm md:text-base font-medium flex items-center">
                        <i class="fa-solid fa-location-dot text-gold mr-3 text-xl"></i>
                        {{ bien.ville }}, {{ bien.quartier }}
                    </p>
                </div>
                
                <div data-aos="fade-left" data-aos-delay="300" class="glass p-6 rounded-3xl text-right min-w-[250px]">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-300 mb-1">Prix demandé</p>
                    <p class="text-3xl md:text-4xl font-black text-white">
                        {{ bien.prix|number_format(0, ',', ' ') }} <span class="text-sm text-gold">GNF</span>
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block content %}
<div class="pb-24 pt-12 bg-slate-50 min-h-screen -mt-4 relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col lg:flex-row gap-12">
            
            <!-- Main Content -->
            <div class="lg:w-2/3 space-y-12">
                
                <!-- Quick Features -->
                <div data-aos="fade-up" data-aos-delay="400" class="premium-card bg-white p-8 grid grid-cols-2 md:grid-cols-4 gap-6 divide-x divide-slate-100">
                    <div class="text-center px-4">
                        <i class="fa-solid fa-maximize text-2xl text-slate-300 mb-3"></i>
                        <p class="text-xl font-black text-dark">{{ bien.surface }} <span class="text-xs">m²</span></p>
                        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-1">Surface</p>
                    </div>
                    <div class="text-center px-4">
                        <i class="fa-solid fa-bed text-2xl text-slate-300 mb-3"></i>
                        <p class="text-xl font-black text-dark">{{ bien.nbPieces }}</p>
                        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-1">Pièces</p>
                    </div>
                    <div class="text-center px-4">
                        <i class="fa-solid fa-calendar-days text-2xl text-slate-300 mb-3"></i>
                        <p class="text-xl font-black text-dark">{{ bien.createdAt|date('Y') }}</p>
                        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-1">Année</p>
                    </div>
                    <div class="text-center px-4">
                        <i class="fa-solid fa-tag text-2xl text-slate-300 mb-3"></i>
                        <p class="text-xl font-black text-dark">{{ bien.type }}</p>
                        <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-1">Type</p>
                    </div>
                </div>

                <!-- Description -->
                <div data-aos="fade-up" data-aos-delay="500" class="premium-card bg-white p-10">
                    <h3 class="font-serif text-3xl text-dark mb-8">À propos de ce bien</h3>
                    <div class="prose prose-slate max-w-none text-slate-600 leading-loose text-sm">
                        {{ bien.description|nl2br }}
                    </div>
                </div>

                <!-- Features/Amenities (Placeholder if not in entity) -->
                <div data-aos="fade-up" data-aos-delay="600" class="premium-card bg-white p-10">
                    <h3 class="font-serif text-3xl text-dark mb-8">Prestations</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="flex items-center text-sm font-bold text-slate-700">
                            <i class="fa-solid fa-check text-premium w-6"></i> Climatisation
                        </div>
                        <div class="flex items-center text-sm font-bold text-slate-700">
                            <i class="fa-solid fa-check text-premium w-6"></i> Parking sécurisé
                        </div>
                        <div class="flex items-center text-sm font-bold text-slate-700">
                            <i class="fa-solid fa-check text-premium w-6"></i> Groupe électrogène
                        </div>
                        <div class="flex items-center text-sm font-bold text-slate-700">
                            <i class="fa-solid fa-check text-premium w-6"></i> Forage
                        </div>
                    </div>
                </div>

            </div>

            <!-- Sticky Sidebar -->
            <div data-aos="fade-left" data-aos-delay="400" class="lg:w-1/3">
                <div class="sticky top-28 space-y-6">



                    {# ===== ADMIN & AGENT: Actions d'administration ===== #}
                    {% if is_granted('BIEN_UPDATE', bien) %}
                        <div class="premium-card bg-white p-6 border-l-4 border-premium">
                            <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-4"
                                ><i class="fa-solid fa-gears mr-2 text-indigo-400"></i>Administration</h4>
                            <div class="flex flex-col gap-2">
                                <a href="{{ path('biens.edit', {id: bien.id}) }}" class="w-full py-3 bg-slate-50 hover:bg-indigo-600 hover:text-white text-center rounded-xl text-xs font-black uppercase tracking-widest transition-colors text-slate-700 flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-pen-to-square"></i> Modifier le bien
                                </a>
                                {% if is_granted('BIEN_VALIDATE', bien) and bien.statut == 'en_attente' %}
                                    <form method="POST" action="{{ path('biens.publier', {id: bien.id}) }}" class="w-full space-y-3">
                                        <input type="hidden" name="_token" value="{{ csrf_token('publish'~bien.id) }}">
                                        
                                        <div>
                                            <label for="agent_id" class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Assigner un Agent Commercial</label>
                                            <select name="agent_id" id="agent_id" required class="block w-full rounded-xl border-slate-200 bg-slate-50 focus:border-indigo-500 focus:ring-0 text-xs font-bold text-slate-700 py-3">
                                                <option value="">-- Choisir un agent --</option>
                                                {% for agent in agents %}
                                                    <option value="{{ agent.id }}">{{ agent.name }} ({{ agent.email }})</option>
                                                {% endfor %}
                                            </select>
                                        </div>

                                        <button type="submit" class="w-full py-3 bg-emerald-500 text-white rounded-xl text-xs font-black uppercase tracking-widest hover:bg-emerald-600 transition-colors flex items-center justify-center gap-2">
                                            <i class="fa-solid fa-check-circle"></i> Valider & Publier
                                        </button>
                                    </form>
                                {% endif %}
                                {% if is_granted('BIEN_UPDATE', bien) and bien.statut in ['publié', 'suspendu'] %}
                                    <form method="POST" action="{{ path('biens.suspendre', {id: bien.id}) }}" class="w-full">
                                        <button type="submit" class="w-full py-3 {{ bien.statut == 'suspendu' ? 'bg-indigo-500 hover:bg-indigo-600' : 'bg-amber-500 hover:bg-amber-600' }} text-white rounded-xl text-xs font-black uppercase tracking-widest transition-colors flex items-center justify-center gap-2">
                                            <i class="fa-solid {{ bien.statut == 'suspendu' ? 'fa-eye' : 'fa-eye-slash' }}"></i>
                                            {{ bien.statut == 'suspendu' ? 'Remettre en ligne' : 'Suspendre' }}
                                        </button>
                                    </form>
                                {% endif %}
                                {% if is_granted('BIEN_DELETE', bien) %}
                                    <form method="POST" action="{{ path('biens.destroy', {id: bien.id}) }}" onsubmit="return confirm('Supprimer ce bien définitivement ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete'~bien.id) }}">
                                        <button type="submit" class="w-full py-3 bg-rose-50 text-rose-500 hover:bg-rose-500 hover:text-white rounded-xl text-xs font-black uppercase tracking-widest transition-colors flex items-center justify-center gap-2">
                                            <i class="fa-solid fa-trash-can"></i> Supprimer
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}


                    {# ===== CLIENT: Prendre rendez-vous ===== #}
                    {% if app.user and is_granted('ROLE_CLIENT') and bien.statut == 'publié' %}
                        <div class="premium-card bg-white p-6">
                            <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-4"
                                ><i class="fa-solid fa-calendar-check mr-2 text-indigo-400"></i>Planifier une Visite</h4>
                            <a href="{{ path('visites.create', {bien_id: bien.id}) }}" class="w-full flex items-center justify-center py-4 bg-indigo-600 text-white rounded-xl text-sm font-black uppercase tracking-widest hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-600/30 group hover:-translate-y-1">
                                <i class="fa-solid fa-calendar-check mr-2 group-hover:scale-125 transition-transform"></i>
                                Prendre Rendez-vous
                            </a>
                        </div>
                    {% elseif not app.user %}
                        <div class="premium-card bg-white p-6">
                            <a href="{{ path('app_login') }}" class="w-full flex items-center justify-center py-4 bg-slate-100 text-slate-600 rounded-xl text-xs font-black uppercase tracking-widest hover:bg-slate-200 transition-colors">
                                <i class="fa-solid fa-right-to-bracket mr-2"></i> Connectez-vous pour visiter
                            </a>
                        </div>
                    {% endif %}

                    {# ===== Contact Agent (visible par tous) ===== #}
                    <div class="premium-card bg-white p-8">
                        <div class="text-center mb-8 pb-8 border-b border-slate-50">
                            <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-slate-50 mx-auto mb-4">
                                {% if bien.agent and bien.agent.photoUrl %}
                                    <img src="{{ asset(bien.agent.photoUrl) }}" class="w-full h-full object-cover">
                                {% else %}
                                    <div class="w-full h-full bg-indigo-50 text-premium flex items-center justify-center">
                                        <i class="fa-solid fa-user-tie text-3xl"></i>
                                    </div>
                                {% endif %}
                            </div>
                            <h4 class="font-black text-lg text-dark mb-1">{{ bien.agent.name|default('Agent ImmoPro') }}</h4>
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Expert Immobilier</p>
                        </div>

                        <div class="mt-6 pt-6 border-t border-slate-50 flex justify-center space-x-4">
                            <a href="tel:{{ bien.agent.phone|default(global_settings.agency_phone) }}" class="w-12 h-12 rounded-full bg-slate-50 text-dark flex items-center justify-center hover:bg-premium hover:text-white transition-colors">
                                <i class="fa-solid fa-phone"></i>
                            </a>
                            <a href="https://wa.me/{{ bien.agent.phone|default(global_settings.agency_phone)|replace({' ': '', '+': ''}) }}" target="_blank" class="w-12 h-12 rounded-full bg-emerald-50 text-emerald-600 flex items-center justify-center hover:bg-emerald-500 hover:text-white transition-colors">
                                <i class="fa-brands fa-whatsapp text-lg"></i>
                            </a>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

